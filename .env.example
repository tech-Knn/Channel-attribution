# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/channel_attribution

# Redis
REDIS_URL=redis://localhost:6379

# AdSense / AFS
ADSENSE_PUBLISHER_ID=pub-0000000000000000
ADSENSE_CLIENT_ID=your-client-id.apps.googleusercontent.com
ADSENSE_CLIENT_SECRET=your-client-secret
ADSENSE_REFRESH_TOKEN=your-refresh-token
AFS_PUBLISHER_ID=partner-pub-0000000000000000
AFS_API_KEY=your-afs-api-key

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# Google Analytics 4
GA4_PROPERTY_ID=123456789
GA_SERVICE_ACCOUNT_PATH=/secrets/service-account.json
GA4_REACTIVATION_THRESHOLD=30

# Application
PORT=3000
NODE_ENV=development
